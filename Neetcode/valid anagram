SOLUTION 1:

class Solution {
    public boolean isAnagram(String s, String t) {
        if(s.length() != t.length()){
            return false;
        }
        int freq[] = new int[26];
        for(int i=0; i<s.length(); i++){
            freq[s.charAt(i) - 'a']++;
            freq[t.charAt(i) - 'a']--;
        }
        for(int count : freq){
            if(count != 0){
                return false;
            }
        }
        return true;
    }
}


SOLUTION 2:

class Solution {
    public boolean isAnagram(String s, String t) {
        int freq1[] = new int[26];
        int freq2[] = new int[26];
        if(s.length() != t.length()){
            return false;
        }
        for(int i=0; i<s.length(); i++){
            freq1[s.charAt(i) - 'a']++;
            freq2[t.charAt(i) - 'a']++;
        }
        if(Arrays.equals(freq1, freq2)){
            return true;
        }
        return false;
    }
}
