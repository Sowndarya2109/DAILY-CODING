class Solution {
    public int longestConsecutive(int[] nums) {
        HashSet<Integer> set = new HashSet<>();
        for(int x : nums){
            set.add(x);
        }
       
        int longest = 0; 
        for(int x : set){           
            if(!set.contains(x-1)){
                int count = 1;
                int current = x;
                while(set.contains(current + 1)){
                    current++;
                    count++;
                }
                longest = Math.max(longest, count);
            }
        }
        
        return longest;
    }
}
