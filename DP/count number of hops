class Solution {
    // Function to count the number of ways in which frog can reach the top.
    static int countWays(int n){
        if(n==0) return 1;
        if(n==1) return n;
        if(n==2) return n;
        
        int a=1, b=1, c=2, d=0;
        for(int i=3; i<=n; i++){
            d = a+b+c;
            a = b;
            b = c;
            c = d;
        }
        return d;
    }
}
