/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    int mx = Integer.MIN_VALUE;
    public int helper(TreeNode root){
        if(root == null)
            return 0;
        int lmax = helper(root.left);
        int rmax = helper(root.right);
        int ldash = Math.max(lmax, 0);
        int rdash = Math.max(rmax, 0);
        int csum = ldash + rdash + root.val;
        mx = Math.max(csum, mx);
        return Math.max(ldash, rdash) + root.val;
    }
    public int maxPathSum(TreeNode root) {
        helper(root);
        return mx;
    }
}
