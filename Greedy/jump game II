class Solution {
    public int jump(int[] nums) {
        int jumps = 0;
        int farest_poss = 0;
        int curEnd  = 0;
        for(int i=0; i<nums.length-1; i++){
            farest_poss = Math.max(farest_poss, i+nums[i]);
            if(i == curEnd){
                jumps++;
                curEnd = farest_poss;
            }
        }
        return jumps;
    }
}
