class Solution {
  public int minTaps(int n, int[] ranges) {
        int []startEnd=new int[n+1];
        for(int i=0;i<ranges.length;i++)
        {
            int leftrange=Math.max(0,i-ranges[i]);
            int rightrange=Math.min(n,i+ranges[i]);
            startEnd[leftrange]=Math.max(startEnd[leftrange],rightrange);
        }

        int tap=0;
        int maxend=0;
        int currend=0;
        for(int i=0;i<ranges.length;i++)
        {
            if(i>maxend)
                return -1;
            if(i>currend)
            {
                tap++;
                currend=maxend;
            }
            maxend=Math.max(maxend,startEnd[i]);
        }
        return tap;
    }
}
