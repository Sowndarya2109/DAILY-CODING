class Solution {
    public int maxProfit(int[] prices) {
        int min = prices[0];
        int max = 0;
        int profit = 0;
        for(int x : prices){
            if(x < min){
                min = x;
            }
            profit = x - min;
            if(max < profit){
                max = profit;
            }
        }
        return max;
    }
}
