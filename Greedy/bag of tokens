class Solution {
    public int bagOfTokensScore(int[] tokens, int power) {
        int n = tokens.length;
        Arrays.sort(tokens);
        int i = 0; 
        int j = n-1;
        int maxscore = 0;
        int score = 0;
        while(i <= j){
            if(power >= tokens[i]){
            power -= tokens[i];
            score++;
            maxscore = Math.max(maxscore, score);
            i++;
        }
        else if(score >= 1){
            power += tokens[j];
            j--;
            score--;
        }
        else
            return maxscore;
        }
    return maxscore; 
    }
}
