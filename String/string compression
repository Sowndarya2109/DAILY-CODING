class Solution {
    public int compress(char[] chars) {
       int read = 0, write = 0;
       while(read < chars.length){
        char curchar = chars[read];
        int count = 0;
        while(read < chars.length && chars[read] == curchar){
            read++;
            count++;
        }
        chars[write] = curchar;
        write++;
        if(count > 1){
            for(char c : String.valueOf(count).toCharArray()){
                chars[write] = c;
                write++;
            }
        }
        }
       return write;
    }
}
