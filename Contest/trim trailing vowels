class Solution {
    public String trimTrailingVowels(String s) {
        char str[] = s.toCharArray();
        String result = "";
        int end = str.length-1;
        while(end >= 0 && 
             (str[end] == 'a' || str[end] == 'e' || str[end] == 'i' || str[end] == 'o' || str[end] == 'u')){
             end--;
             }
        for(int i=0; i<=end; i++){
            result += str[i];
        }
        return result;
    }
}©leetcode
