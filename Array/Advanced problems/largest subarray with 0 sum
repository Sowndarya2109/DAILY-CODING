class Solution {
    int maxLength(int arr[]) {
        int sum = 0, maxLen = 0;
        int n = arr.length;
        HashMap<Integer, Integer> map = new HashMap<>();
        for(int i=0; i<n; i++){
            sum += arr[i];
            if(sum == 0)
            maxLen = i+1;
            if(map.containsKey(sum)){
                maxLen = Math.max(maxLen, i-map.get(sum));
            }else
            map.put(sum, i);
        } 
        return maxLen;
    }
}
